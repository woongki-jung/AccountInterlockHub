{
  "name": "@accountinterlockhub/backend",
  "version": "0.1.0",
  "private": true,
  "description": "AccountInterlockHub 백엔드 — NestJS API + React 정적 서빙 + 상태 보관 배치(단일 App Service)",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "migration:run": "nest build && node --env-file=.env dist/database/run-migrations.js",
    "migration:revert": "nest build && node --env-file=.env dist/database/run-migrations.js --revert",
    "seed:admin": "nest build && node --env-file=.env dist/database/seed-admin.js",
    "batch:retention": "nest build && node --env-file=.env dist/batch/run-retention-batch.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "express": "^5.0.0",
    "express-session": "^1.19.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.0 || ^1.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.0.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
