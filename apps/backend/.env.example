# AccountInterlockHub 백엔드 환경변수 예시.
# 실제 값은 apps/backend/.env (git 비관리)로 복제해 채운다. 비밀 값은 커밋하지 않는다.
# 개발·로컬은 별도 구축 PostgreSQL 서버를 사용한다(devspec/infra.md §환경 구분).

# 애플리케이션
PORT=3000
NODE_ENV=development
# 프런트엔드 정적 산출물 경로(미지정 시 apps/frontend/dist 를 기본 사용)
# FRONTEND_DIST_PATH=

# 관리자 IP 접근 제어 (PROC-104 · FN-001 · SEC-001) — 운영 구성값(코드 하드코딩 금지, SEC-001-02)
# 허용 IP·CIDR 콤마 구분. dev/local(NODE_ENV=dev/development)에서 비우면 IP 제한 비활성(EXC-SEC-01, 로그인 인증은 유지).
# 운영에서는 반드시 채운다(비우면 관리자 경로 전량 403 EX-SEC-001). 예) 203.0.113.7,10.0.0.0/24
ADMIN_IP_ALLOWLIST=
# 프록시/LB 뒤에서 X-Forwarded-For 최좌측(원 클라이언트)을 출발지로 신뢰할지 여부(1/true 로 활성). 기본: 소켓 원 IP 신뢰.
TRUST_PROXY=

# 데이터베이스 (PostgreSQL 16) — 값은 로컬 .env 에만 채운다
DB_HOST=localhost
DB_PORT=55432
DB_NAME=accountinterlockhub
DB_USER=aih_app
DB_PASSWORD=changeme
