# AccountInterlockHub 백엔드 환경변수 예시.
# 실제 값은 apps/backend/.env (git 비관리)로 복제해 채운다. 비밀 값은 커밋하지 않는다.
# 개발·로컬은 별도 구축 PostgreSQL 서버를 사용한다(devspec/infra.md §환경 구분).

# 애플리케이션
PORT=3000
NODE_ENV=development
# 프런트엔드 정적 산출물 경로(미지정 시 apps/frontend/dist 를 기본 사용)
# FRONTEND_DIST_PATH=

# 관리자 IP 접근 제어 (PROC-104 · FN-001 · SEC-001) — 운영 구성값(코드 하드코딩 금지, SEC-001-02)
# 허용 IP·CIDR 콤마 구분. dev/local(NODE_ENV=dev/development)에서 비우면 IP 제한 비활성(EXC-SEC-01, 로그인 인증은 유지).
# 운영에서는 반드시 채운다(비우면 관리자 경로 전량 403 EX-SEC-001). 예) 203.0.113.7,10.0.0.0/24
ADMIN_IP_ALLOWLIST=
# 프록시/LB 뒤에서 X-Forwarded-For 최좌측(원 클라이언트)을 출발지로 신뢰할지 여부(1/true 로 활성). 기본: 소켓 원 IP 신뢰.
# production 에서 TLS 를 종단하는 프록시/PaaS 엣지(예: Azure App Service) 뒤에 배치할 때는 반드시 1/true 로
# 설정한다 — express-session 이 X-Forwarded-Proto 헤더를 신뢰해 관리자 세션 secure 쿠키(FN-003·AUTH-002-02)를
# 발급하는 유일한 경로다(session.support.ts buildSessionOptions 의 proxy 옵션). 미설정 시 로그인 API 는 200 을
# 반환하지만 Set-Cookie 가 전혀 발급되지 않아 이후 모든 관리자 요청이 401 EX-AUTH-001 로 실패한다(관리자 콘솔
# 전체 사용 불가 — production 전용 결함, 일감 #235). 이 플래그는 관리자 IP 게이트·진입 요청제한의 출발지 IP
# 판별(XFF, 오류 #213)에도 쓰이며 두 용도 모두 같은 신뢰 경계를 공유한다 — 신뢰 프록시가 XFF·X-Forwarded-Proto
# 를 모두 정확히 설정하는 배포에서만 켠다.
TRUST_PROXY=

# 데이터베이스 (PostgreSQL 16) — 값은 로컬 .env 에만 채운다
DB_HOST=localhost
DB_PORT=55432
DB_NAME=accountinterlockhub
DB_USER=aih_app
DB_PASSWORD=changeme

# 관리자 로그인·세션 (PROC-103 · FN-002 · FN-003)
# 세션 서명 비밀(운영 필수·긴 난수). dev 미설정 시 안전하지 않은 기본값으로 대체된다.
SESSION_SECRET=
# 세션 유휴 만료(분). 기본 30(AUTH-002-01). EX-AUTH-002 재현 시 낮춰 검증(예: 1).
SESSION_IDLE_MINUTES=30

# 관리자 시드 계정(ENT-005 운영 프로비저닝 대체, 멱등 upsert). npm run seed:admin 로 반영.
# 비밀번호는 8자 이상 + 영대문자·소문자·숫자·특수문자 각 1자 이상(AUTH-001-02). 실계정 자격은 커밋 금지.
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=

# 서비스 대면 API 인증 (FN-004 · SEC-003) — 사전 발급 API 키 + HMAC-SHA256 서명. 주체별 분리(SEC-003-03).
# 자격은 운영 구성값(비밀·ENT 아님)이며 커밋 금지. 미설정 주체는 fail-closed(401 EX-SEC-003)로 동작한다.
#   - SERVICE_A: 서비스 A 대면 API(API-01 처리상태 확인·API-02 연동 완료 확인) 호출 주체.
#   - SERVICE_B: 서비스 B 대면 API(API-03 완료 콜백) 호출 주체.
# 인증 스킴(요청 헤더 3종):
#   X-Api-Key   : 호출 주체 키 ID(= SERVICE_x_API_KEY 값). 서비스 A/B 식별.
#   X-Timestamp : unix epoch seconds(정수 문자열). abs(now - ts) <= 300s(재전송 방지).
#   X-Signature : hex(HMAC-SHA256(canonical, SERVICE_x_API_SECRET)).
# canonical string = `${METHOD}\n${path}\n${timestamp}\n${bodyHashHex}`
#   METHOD=HTTP 메서드 대문자 / path=쿼리 제외 요청 경로 / timestamp=X-Timestamp 원문
#   bodyHashHex=hex(sha256(rawBody)) (본문 없으면 빈 문자열의 sha256)
# 키·비밀은 충분히 긴 난수로 생성해 채운다(A/B 각각 고유). 예) openssl rand -hex 32
SERVICE_A_API_KEY=
SERVICE_A_API_SECRET=
SERVICE_B_API_KEY=
SERVICE_B_API_SECRET=
