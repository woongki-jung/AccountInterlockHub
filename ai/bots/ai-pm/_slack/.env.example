# ai-pm Slack 자격증명 — 본 파일을 .env 로 복사한 뒤 발급 토큰을 채운다.
# .env 는 git 비관리(.gitignore). 토큰을 메시지·로그·커밋에 노출하지 않는다.
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...

# (선택) 아래 두 키는 세션 래퍼(ai-pm-session.ps1)가 세션 정체성 주입용으로 읽는다 —
# 미설정 시 Redmine MCP 는 서버 기본 admin 키로 폴백한다. 실값은 .env 에만 채운다.
# REDMINE_BASE_URL=
# REDMINE_API_KEY=
